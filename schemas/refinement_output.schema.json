{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RefinementOutput",
  "type": "object",
  "required": ["parent_summary", "children"],
  "properties": {
    "parent_summary": {
      "type": "string"
    },
    "children": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "requirement_text",
          "req_type",
          "metric",
          "operator",
          "target_value",
          "units",
          "test_method",
          "acceptance_window",
          "tags"
        ],
        "properties": {
          "requirement_text": {"type": "string"},
          "req_type": {"type": "string"},
          "metric": {"type": "string"},
          "operator": {"type": "string"},
          "target_value": {"type": ["string", "number"]},
          "units": {"type": "string"},
          "test_method": {"type": "string"},
          "acceptance_window": {"type": "string"},
          "tags": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

